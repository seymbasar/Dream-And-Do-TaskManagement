@using EntityLayer.Conrete
@model List<Board>

@{
    ViewBag.Title = "Dream & Do";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="board-container">
    @foreach (var item in Model)
    {
        <div class="card">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                <h3 style="margin:0; cursor:pointer;">@item.BoardName</h3>
                <button class="delete-card-btn" onclick="askDeleteBoard(@item.BoardID, '@item.BoardName')" style="background:none; border:none; color:#e74c3c; cursor:pointer; font-size:1.5rem;">&times;</button>
            </div>

            <ul class="todo-list" style="min-height: 30px;">
                @if (item.Lists != null)
                {
                    foreach (var list in item.Lists)
                    {
                        foreach (var card in list.Cards)
                        {
                            @* DURUM KONTROLÜ: Status false ise completed class'ı ekle *@
                            <div class="todo @(card.CardStatus == false ? "completed" : "")">
                            <li class="todo-item">@card.CardName</li>
                            <div style="display: flex;">
                                @* TIKLAMA OLAYI: Bu butona basınca JS fonksiyonu çalışacak *@
                                <button class="check-btn" onclick="toggleTask(this, @card.CardID)">
                                    <i class="fas fa-check"></i>
                                </button>
                                <button class="delete-btn" onclick="window.location.href='/Board/DeleteCard/@card.CardID'">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                    </div>
                }
            }
        }
                </ul>

                @using (Html.BeginForm("AddCard", "Board", FormMethod.Post))
                {
                    <div class="card-footer" style="display:flex; margin-top:10px; gap:5px;">
                        <input type="hidden" name="boardId" value="@item.BoardID" />
                        <input type="text" name="cardName" class="item-in" placeholder="Ekle..." style="flex:1; padding:8px; border-radius:5px; border:none; color:#333;" required>
                        <button type="submit" class="item-add" style="border-radius:5px; border:none; padding:0 15px; cursor:pointer; background:#2ecc71; color:white;">+</button>
                    </div>
                }
            </div>
        }
    </div>
